[flake8]
# E501 — line too long: long prompt strings are intentional
# W503 — line break before binary operator: conflicts with Black style
# E203 — whitespace before ':': Black-compatible slice notation
# F541 — f-string without placeholders: print() calls use f-strings consistently
extend-ignore = E501,W503,E203,F541

per-file-ignores =
    # sys.path.insert before imports (required for Streamlit); pre-existing unused
    # imports and style issues in the large dashboard file
    ssed/dashboard.py:E402,F401,E302,F841
    # One unused scipy import left from an earlier draft
    ssed/quant_signals.py:F401
